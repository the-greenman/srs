    "records/tier-2/purpose-1ad5532f.json": {
      "createdAt": "2026-07-11T00:00:00Z",
      "fieldValues": [
        {
          "fieldId": "3b000001-0000-4000-a000-000000000001",
          "value": "LiMoMa — the Limehouse Museum of Maybe Art — curates, installs, and maintains a rotating display of artwork in the back stairwell and landings of Limehouse Town Hall, operating as a voluntary association of members. The pilot runs for six months from June 2026."
        }
      ],
      "instanceId": "1ad5532f-43c8-4ec7-8a45-39e97c60dbc6",
      "typeId": "3c000001-0000-4000-a000-000000000001",
      "typeName": "purpose",
      "typeNamespace": "com.semanticops.core",
      "typeVersion": 1
    },
    "records/tier-2/role-448d64d4.json": {
      "createdAt": "2026-05-31T14:55:35.200802911+00:00",
      "fieldValues": [
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "R-003 Clerk"
        },
        {
          "fieldId": "a6c19b95-4f8f-5b07-93f8-3426c545277e",
          "value": "Peter Brownell"
        },
        {
          "fieldId": "d25da548-79d6-555b-8878-f40b685b3955",
          "value": "May write up and maintain the decision log, Articles, and role records. May flag when a proposed action appears inconsistent with a recorded decision or article. Responsible for ensuring that Article A-006 (On ending) obligations are discharged when the time comes."
        },
        {
          "fieldId": "3c39ee1f-6fe0-5da7-a0b6-928aa3a63211",
          "value": "Cannot decide what is shown or how it is installed. The Clerk's role is to maintain the record faithfully — not to determine its content. Cannot amend a decision unilaterally; can only record what the group has agreed."
        },
        {
          "fieldId": "9a32dc01-f348-5e05-9f54-bb6d21239f04",
          "value": "Established by Article A-004 (How we make decisions)."
        }
      ],
      "instanceId": "448d64d4-ae82-4971-b027-3b78b9c7a90a",
      "lifecycleState": "ratified",
      "typeId": "e53dce11-6b83-5714-a8fe-f730edb500fa",
      "typeName": "role",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:18.539183633+00:00"
    },
    "records/tier-2/role-5bbf9209.json": {
      "createdAt": "2026-05-31T14:55:35.195104906+00:00",
      "fieldValues": [
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "R-001 Building Authority"
        },
        {
          "fieldId": "a6c19b95-4f8f-5b07-93f8-3426c545277e",
          "value": "Sam Hayder"
        },
        {
          "fieldId": "d25da548-79d6-555b-8878-f40b685b3955",
          "value": "May decide what fixings and mounting methods are acceptable for the physical fabric of the building. May halt or reverse installation work that risks damage to walls, plaster, or structural elements. Has final say on whether a proposed intervention is safe and appropriate."
        },
        {
          "fieldId": "3c39ee1f-6fe0-5da7-a0b6-928aa3a63211",
          "value": "Cannot decide what artwork is shown or how it is curated — that is the Curatorial Lead's authority. Cannot commit the group to structural changes without Party Utility agreement. Cannot override A-005 (Care of the building)."
        },
        {
          "fieldId": "9a32dc01-f348-5e05-9f54-bb6d21239f04",
          "value": "Inherited from the Party Utility, who granted access to the back stairs and entrusted Sam with responsibility for the physical space."
        }
      ],
      "instanceId": "5bbf9209-1dc9-44b2-b0a3-f2192db5a879",
      "lifecycleState": "ratified",
      "typeId": "e53dce11-6b83-5714-a8fe-f730edb500fa",
      "typeName": "role",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:18.642631786+00:00"
    },
    "records/tier-2/role-8ed62308.json": {
      "createdAt": "2026-05-31T14:55:35.198208984+00:00",
      "fieldValues": [
        {
          "fieldId": "d7e82557-9045-5e92-a494-d99112bbec4a",
          "value": "R-002 Curatorial Lead"
        },
        {
          "fieldId": "a6c19b95-4f8f-5b07-93f8-3426c545277e",
          "value": "Immo Klink"
        },
        {
          "fieldId": "d25da548-79d6-555b-8878-f40b685b3955",
          "value": "May select which works are exhibited and which artists are invited to show during Phase 1. May decide placement and arrangement within the space, subject to Building Authority approval of any installation method. May set the thematic direction of a show."
        },
        {
          "fieldId": "3c39ee1f-6fe0-5da7-a0b6-928aa3a63211",
          "value": "Cannot approve installation methods or fixings — that is Building Authority. Cannot commit to showing work that would require structural changes not yet approved. Cannot enter financial agreements on behalf of the group."
        },
        {
          "fieldId": "9a32dc01-f348-5e05-9f54-bb6d21239f04",
          "value": "Delegated by the founding group at the founding meeting, May 2026. Role is Phase 1 scoped — to be reviewed at the pilot review in December 2026."
        },
        {
          "fieldId": "c04b7f84-9a55-5353-8c9f-2b62f6a1e34e",
          "value": "December 2026 pilot review."
        }
      ],
      "instanceId": "8ed62308-f7b4-47e1-b1a2-5490908efd86",
      "lifecycleState": "ratified",
      "typeId": "e53dce11-6b83-5714-a8fe-f730edb500fa",
      "typeName": "role",
      "typeNamespace": "governance",
      "typeVersion": 1,
      "updatedAt": "2026-06-08T21:05:18.757652487+00:00"
    },
