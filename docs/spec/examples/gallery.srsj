    "package/views/decision-log-faebd240.json": {
      "createdAt": "2026-06-01T00:00:00Z",
      "description": "Compact decision log field view showing statement, alternatives, rationale, and revisit trigger.",
      "fieldViews": [
        {
          "displayLabel": "Decision",
          "fieldId": "de1296e0-e083-58d9-97a0-cb2b91fec02e",
          "order": 0,
          "required": true,
          "visible": true
        },
        {
          "displayLabel": "Alternatives",
          "fieldId": "636ce948-2110-57b4-a3ed-04354ec17843",
