    "package/lifecycles/governancelifecycle-3c504040.json": {
      "createdAt": "2026-06-08T00:00:00Z",
      "description": "Shared governance lifecycle for Articles, Roles, and Decisions. A record is drafted, proposed to the group, and ratified once agreed. Ratified records either close (obligation discharged) or are superseded by a successor. closed and superseded are final.",
      "id": "3c504040-7920-43aa-8fbd-eda21dc7c07b",
      "initialState": "draft",
      "name": "governance_lifecycle",
      "namespace": "governance",
      "states": [
        {
          "description": "Being written; not yet put to the group.",
          "id": "f439ed11-6ad7-466a-9544-c6f68946e7d1",
          "isInitial": true,
          "key": "draft",
          "label": "Draft"
        },
        {
          "description": "Put to the group for agreement.",
          "id": "5c995a40-247d-4438-8799-768caefed24f",
          "key": "proposed",
          "label": "Proposed"
        },
        {
          "description": "Agreed by the group and in force.",
          "id": "cbb5354a-e9ea-419a-9496-c741c80ebdcb",
          "key": "ratified",
          "label": "Ratified"
        },
        {
          "description": "Obligation discharged or matter concluded; no successor.",
          "id": "30e0cae8-e363-4084-b244-d261e0fe4661",
          "isFinal": true,
          "key": "closed",
          "label": "Closed"
        },
        {
          "description": "Replaced by a successor record.",
          "id": "ec97cea2-9d19-4940-b101-75282f37fa50",
          "isFinal": true,
          "key": "superseded",
          "label": "Superseded",
          "requiresRelation": {
            "relationType": "supersedes"
          }
        }
      ],
      "transitions": [
        {
          "description": "Put a draft to the group.",
          "from": "draft",
          "id": "66910ac8-a34d-4178-9c87-e78a0d853726",
          "name": "propose",
          "to": "proposed"
        },
        {
          "description": "Withdraw a proposal for further drafting.",
          "from": "proposed",
          "id": "3795dc5e-9b84-4c54-9760-2a059338c80f",
          "name": "revise",
          "to": "draft"
        },
        {
          "description": "Group agrees; the record comes into force.",
          "from": "proposed",
          "id": "2a2898fb-a29d-4112-9408-b7b1af60e9e7",
          "name": "ratify",
          "to": "ratified"
        },
        {
          "description": "Replace with a successor record.",
          "from": "ratified",
          "id": "349b93bb-c5b2-4888-a3e4-772deaf554ff",
          "name": "supersede",
          "to": "superseded"
        },
        {
          "description": "Conclude the matter with no successor.",
          "from": "ratified",
          "id": "14ff9216-e7ae-4b3c-88a7-db44534b46ae",
          "name": "close",
          "to": "closed"
        }
      ],
      "version": 1
    },
