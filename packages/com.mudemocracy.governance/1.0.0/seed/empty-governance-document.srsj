      "description": "What this role may decide or act on without requiring group agreement.",
      "id": "d25da548-79d6-555b-8878-f40b685b3955",
      "name": "authority",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/boundary-3c39ee1f.json": {
      "aiGuidance": {
        "purpose": ""
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "The limits of this role — where the role's authority ends or must be shared.",
      "id": "3c39ee1f-6fe0-5da7-a0b6-928aa3a63211",
      "name": "boundary",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/context-9889052c.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision — LiMoMa founding session",
            "output": "The group formed in March 2026 and agreed to trial a flat structure for six months. That trial period ends in December, and the group now needs to decide how to structure ongoing work."
          }
        ],
        "extraction": "Look for background information stated before the decision point: prior agreements, historical context, changes in circumstances, or what happened to prompt this discussion. Extract the scene, not the problem.",
        "negativeGuidance": "Do not include the friction or problem itself — that belongs in the Friction field. Context sets the stage; it does not name the pain.",
        "purpose": "Captures the history, constraints, and trigger event that make this decision matter — the scene-setting before the problem itself is named."
      },
      "createdAt": "2026-05-25T00:00:00Z",
      "description": "Background that makes the matter meaningful.",
      "id": "9889052c-9313-5e2f-a2ac-15baa3c6983e",
      "instructions": "Set the scene: what happened before, and the limits you are working within — prior agreements, history, or constraints like budget, law, or deadlines. Explain the environment the group is in now. Do not name the problem itself here — that goes in Friction; context is the backdrop, not the pain.",
      "name": "context",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/decisionquestion-73cd845a.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision",
            "output": "How often should we meet as a group?"
          }
        ],
        "extraction": "Look for the moment someone names what is actually being decided: so the question is..., what we are deciding is..., or an implicit framing that narrows discussion to one choice point. If no explicit question was stated, infer the minimal question the decision statement answers.",
        "purpose": "States the single concrete question this decision settles. A well-formed decision question is specific enough that the decision statement directly answers it."
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "The single concrete question this decision answers.",
      "id": "73cd845a-3623-5bc6-8ade-42a7cd64740c",
      "instructions": "State the single concrete question this decision settles — specific enough that the decision statement is a direct answer to it. Try phrasing it as “Should we…?” or “How should we…?”. If you find you are only deciding the next task, step up to the higher-level question underneath it.",
      "name": "decision_question",
      "namespace": "governance",
      "valueType": "string",
      "version": 1
    },
    "package/fields/decisionstatement-de1296e0.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision",
            "output": "We will meet fortnightly, on Tuesdays at 18:00 UTC, starting from the first Tuesday in July."
          }
        ],
        "extraction": "Look for the moment agreement is reached — signalled by so we are agreed, let us go with, or a direct statement of resolution. Extract the commitment itself, not the discussion around it. One sentence.",
        "purpose": "States the settled commitment in one concise, active-voice sentence. This is the record of what was decided, not why."
      },
      "createdAt": "2026-05-25T00:00:00Z",
      "description": "The settled commitment in one active-voice sentence.",
      "id": "de1296e0-e083-58d9-97a0-cb2b91fec02e",
      "instructions": "Write the settled commitment as one clear sentence in the active voice — start with “We will…” or “We have decided to…” so the outcome is unmistakable. Capture what was agreed, not the discussion around it, and make it specific enough to act on: name the who, what, and when where they were agreed.",
      "name": "decision_statement",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/friction-1a1c0a5d.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision",
            "output": "Without a regular meeting time, coordination is happening ad hoc and some members feel out of the loop. The absence of structure is creating unequal access to decisions."
          }
        ],
        "extraction": "Look for expressions of frustration, tension, or a named gap in current practice. The friction answers why this needs to be decided today. Extract it as a concrete condition, not a wish.",
        "negativeGuidance": "Do not describe what the group wants to do about the friction — that belongs in Alternatives or the Decision Statement. Friction is the forcing function, not the solution direction.",
        "purpose": "Names the specific pain, conflict, or gap that is forcing a decision right now — the concrete thing that cannot be left unresolved."
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "The specific pain, conflict, or gap that makes a decision necessary now.",
      "id": "1a1c0a5d-a1df-5d03-95f2-32af73bb71da",
      "instructions": "Name the specific tension, conflict, or gap that makes a decision necessary now — the concrete pain, not a wish. A good test: if you do nothing, what happens next? Describe the gap between where you are and where you want to be. Do not describe what you want to do about it yet — that comes later.",
      "name": "friction",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/keyrequirements-a952604c.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision",
            "output": "Availability across time zones; not overwhelming volunteers; meeting minimum coordination needs for the pilot period. One member felt fortnightly was still too frequent for their schedule."
          }
        ],
        "extraction": "Look for statements about what matters most, explicit trade-offs named, objections raised, and any disagreement about the decision or its criteria. Extract both the criteria used and any tension between them.",
        "purpose": "Captures the judging criteria, trade-offs acknowledged, and any recorded disagreement that shaped how the alternatives were evaluated."
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "The standards, values, constraints, and trade-offs used to evaluate options.",
      "id": "a952604c-d150-5315-bfc1-7229ddc1d636",
      "instructions": "Record the standards you used to judge the options — the non-negotiables (cost, deadlines, legal limits), how the choice sits against your values, and what you would be giving up. Note any trade-offs weighed and any disagreement in the room. This is what “a good decision” looks like for this problem.",
      "name": "key_requirements",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/nextsteps-4181f210.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision",
            "output": "Yuki to send calendar invites for the fortnightly Tuesday slot by end of the week."
          }
        ],
        "extraction": "Look for action assignments after the decision point: X will do Y by Z, the first step is..., or concrete commitments. Extract owner and timing if named.",
        "purpose": "Lists concrete follow-up actions that emerge from the decision, with named owners and timing where stated. May be empty if no follow-up actions were recorded."
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "Actions or tasks that emerge from the decision.",
      "id": "4181f210-f4be-5587-950e-890eda2a5590",
      "instructions": "List the concrete tasks that follow from the decision, with an owner and a deadline where they were named — who is taking this on, and by when. There may be none, and that is fine; only record follow-up that was actually agreed.",
      "name": "next_steps",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/owner-4b34847c.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Role-based ownership",
            "output": "Coordination lead"
          }
        ],
        "extraction": "Look for explicit ownership statements: X owns this, this sits with the coordination lead, or an implicit assignment when a role is described as responsible. May be a person name or a role title.",
        "purpose": "Identifies the person or role who holds accountability for this decision — who can revisit it, who is responsible for its implementation."
      },
      "createdAt": "2026-05-25T00:00:00Z",
      "description": "Person, role, group, or function responsible for stewardship of this record.",
      "id": "4b34847c-26d1-56be-bc10-844aeb704df7",
      "instructions": "Name the person or role who holds this decision — who is accountable for carrying it out and who can revisit it. A role title (“Coordination lead”) is often more durable than a person’s name, since it survives people coming and going.",
      "name": "owner",
      "namespace": "governance",
      "valueType": "string",
      "version": 1
    },
    "package/fields/protectedstatus-0df40543.json": {
      "aiGuidance": {
        "purpose": ""
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "Whether this article is protected from ordinary amendment by the group.",
      "id": "0df40543-f72a-5471-a7f1-c85c1f1f93e4",
      "name": "protected_status",
      "namespace": "governance",
      "valueType": "string",
      "version": 1
    },
    "package/fields/rationale-3340532b.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision",
            "output": "Fortnightly maintains momentum without becoming a burden. Monthly felt too infrequent for a new group still finding its rhythm; quarterly too sparse to build shared understanding."
          }
        ],
        "extraction": "Look for statements about why the group chose what they chose: the reasoning given for the final decision, what made this option preferable to the others. Capture the outcome logic, not the deliberation process.",
        "negativeGuidance": "Do not write a blow-by-blow account of the discussion. Do not include objections that were not ultimately deciding factors. The rationale is the deciding logic, not a summary of the meeting.",
        "purpose": "Explains the deciding factor — why this option was chosen over the alternatives. One to three sentences capturing the core reasoning."
      },
      "createdAt": "2026-05-25T00:00:00Z",
      "description": "Why this option over the alternatives.",
      "id": "3340532b-d845-5e54-92b3-819ed05365c5",
      "instructions": "Say what made this the right choice — the deciding factor, in two to four sentences. Focus on the outcome logic, not a blow-by-blow of the debate: this is here to remind your future selves, and anyone not in the room, why the choice made sense. Include the key evidence that tipped it.",
      "name": "rationale",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/revisitwhen-c04b7f84.json": {
      "aiGuidance": {
        "examples": [
          {
            "description": "Meeting-frequency decision",
            "output": "If attendance drops below three members for two consecutive sessions, or at the end of the pilot period in December 2026."
          }
        ],
        "extraction": "Look for statements about when to revisit, what would change the decision, or what review conditions were set. Prefer condition-based triggers, which may reference a date as an anchor.",
        "negativeGuidance": "Avoid bare dates without a condition — revisit in December is weaker than revisit if attendance consistently drops or at the end of the pilot period. Dates can anchor a condition but should not replace one.",
        "purpose": "Names the condition or event that should trigger a review of this decision — tied to the underlying reasoning so the review moment is meaningful."
      },
      "createdAt": "2026-05-25T00:00:00Z",
      "description": "The condition or event that would prompt a review of this decision.",
      "id": "c04b7f84-9a55-5353-8c9f-2b62f6a1e34e",
      "instructions": "Describe how you will know this decision may no longer be working — the conditions or events that should trigger a review, tied to your “why”. Avoid setting only a date: a bare “review in December” is weaker than a condition like “if attendance drops below three for two meetings running”. A date can anchor a condition, but should not replace one.",
      "name": "revisit_when",
      "namespace": "governance",
      "valueType": "text",
      "version": 1
    },
    "package/fields/roleholder-a6c19b95.json": {
      "aiGuidance": {
        "purpose": ""
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "The person, team, group, or function currently holding this role.",
      "id": "a6c19b95-4f8f-5b07-93f8-3426c545277e",
      "name": "role_holder",
      "namespace": "governance",
      "valueType": "string",
      "version": 1
    },
    "package/fields/sourceofauthority-9a32dc01.json": {
      "aiGuidance": {
        "purpose": ""
      },
      "createdAt": "2026-05-26T00:00:00Z",
      "description": "How this authority was conferred: inherited, delegated, elected, appointed, constitutional, etc.",
      "id": "9a32dc01-f348-5e05-9f54-bb6d21239f04",
      "name": "source_of_authority",
      "namespace": "governance",
      "valueType": "string",
      "version": 1
    },
    "package/fields/statement-3b000001.json": {
      "$schema": "https://srs.semanticops.com/schema/2.0/field.json",
      "aiGuidance": {
        "purpose": "Concisely state what this repository exists to do or achieve. This is the primary machine-readable identity text for the repository. Write one or two sentences in plain language; avoid jargon. The value must be non-empty."
      },
      "createdAt": "2026-07-08T00:00:00Z",
      "description": "The purpose or mission statement of this repository. Must be non-empty.",
      "editorHint": "textarea",
      "id": "3b000001-0000-4000-a000-000000000001",
      "name": "statement",
      "namespace": "com.semanticops.core",
      "valueType": "text",
      "version": 1
    },
    "package/fields/title-3b000002.json": {
      "$schema": "https://srs.semanticops.com/schema/2.0/field.json",
      "aiGuidance": {
        "purpose": "An optional short label for the purpose record, for use in constrained UI contexts such as sidebars. Prefer the repository manifest title for primary display; use this only when the identity record itself needs a narrow-context label."
      },
      "createdAt": "2026-07-08T00:00:00Z",
      "description": "Short human-readable label for the identity record. Optional. Distinct from the repository manifest title.",
      "editorHint": "singleline",
      "id": "3b000002-0000-4000-a000-000000000002",
      "name": "title",
