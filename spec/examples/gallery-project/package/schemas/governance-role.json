{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://srs.semanticops.com/schema/domain/governance/role/1.json",
  "title": "Governance Role",
  "description": "Domain schema for governance/role typed records.",
  "allOf": [
    { "$ref": "https://srs.semanticops.com/schema/2.0/record.json" }
  ],
  "$defs": {
    "FieldIds": {
      "description": "Known field IDs for governance/role records.",
      "properties": {
        "title":              { "const": "d7e82557-9045-5e92-a494-d99112bbec4a", "description": "order:0 — Role title (required)" },
        "role_holder":        { "const": "a6c19b95-4f8f-5b07-93f8-3426c545277e", "description": "order:1 — Person or group holding the role" },
        "authority":          { "const": "d25da548-79d6-555b-8878-f40b685b3955", "description": "order:2 — What this role may decide (required)" },
        "boundary":           { "const": "3c39ee1f-6fe0-5da7-a0b6-928aa3a63211", "description": "order:3 — Limits of the role (required)" },
        "source_of_authority":{ "const": "9a32dc01-f348-5e05-9f54-bb6d21239f04", "description": "order:4 — How authority was conferred" },
        "status":             { "const": "aee7afe9-6650-5fa4-a61a-495c3b88994b", "description": "order:5 — Lifecycle status (required)" },
        "revisit_when":       { "const": "c04b7f84-9a55-5353-8c9f-2b62f6a1e34e", "description": "order:6 — Review condition" }
      }
    }
  },
  "if": {
    "properties": {
      "typeRef": { "properties": { "semanticObjectType": { "const": "role" } } }
    }
  },
  "then": {
    "required": ["fieldValues"],
    "properties": {
      "fieldValues": {
        "type": "array",
        "allOf": [
          {
            "contains": { "properties": { "fieldId": { "const": "d25da548-79d6-555b-8878-f40b685b3955" } } },
            "minContains": 1,
            "errorMessage": "governance/role requires governance/authority"
          },
          {
            "contains": { "properties": { "fieldId": { "const": "3c39ee1f-6fe0-5da7-a0b6-928aa3a63211" } } },
            "minContains": 1,
            "errorMessage": "governance/role requires governance/boundary"
          }
        ]
      }
    }
  }
}
