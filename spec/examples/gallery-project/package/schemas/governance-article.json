{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scds.io/gallery-example/schemas/governance-article",
  "title": "Governance Article",
  "description": "Domain schema for governance/article typed records.",
  "allOf": [
    { "$ref": "https://srs.semanticops.com/schema/2.0/record.json" }
  ],
  "$defs": {
    "FieldIds": {
      "description": "Known field IDs for governance/article records.",
      "properties": {
        "article_number":   { "const": "60be1468-01bc-5d12-9eea-628f02801893", "description": "order:0 — Stable local reference, e.g. A-001" },
        "title":            { "const": "d7e82557-9045-5e92-a494-d99112bbec4a", "description": "order:1 — Article title (required)" },
        "article_text":     { "const": "8aa3eba2-204b-5ebd-ba7a-be0f066027d6", "description": "order:2 — Operative article text (required)" },
        "rationale":        { "const": "3340532b-d845-5e54-92b3-819ed05365c5", "description": "order:3 — Why this article exists" },
        "amendment_rule":   { "const": "1f01bc6b-39c8-58d7-b1a3-79142623fece", "description": "order:4 — How this article may be amended" },
        "protected_status": { "const": "0df40543-f72a-5471-a7f1-c85c1f1f93e4", "description": "order:5 — Whether protected from ordinary amendment" },
        "status":           { "const": "aee7afe9-6650-5fa4-a61a-495c3b88994b", "description": "order:6 — Lifecycle status (required)" },
        "revisit_when":     { "const": "c04b7f84-9a55-5353-8c9f-2b62f6a1e34e", "description": "order:7 — Review condition" }
      }
    }
  },
  "if": {
    "properties": {
      "typeRef": { "properties": { "semanticObjectType": { "const": "article" } } }
    }
  },
  "then": {
    "required": ["fieldValues"],
    "properties": {
      "fieldValues": {
        "type": "array",
        "contains": {
          "properties": {
            "fieldId": { "const": "8aa3eba2-204b-5ebd-ba7a-be0f066027d6" }
          }
        },
        "minContains": 1,
        "errorMessage": "governance/article requires at least governance/article_text"
      }
    }
  }
}
