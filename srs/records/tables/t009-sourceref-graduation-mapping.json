  "fieldValues": [
    {
      "fieldId": "1a000025-0000-4000-a000-000000000025",
      "value": "**SourceReference → Relation graduation mapping (RFC-023):** when source material referenced by a `sourceRole` provenance pointer is promoted to an instance, the pointer converts to the listed Relation edge. The *referencing instance* carried the sourceRef; the *promoted instance* is created from the source material."
    },
    {
      "fieldId": "1a000026-0000-4000-a000-000000000026",
      "value": "Conversion semantics (RFC-023 R6): the originating role is recorded in `meta[\"com.semanticops.srs/sourceRole\"]` (required for `quoted-from`); `confidence` carries over; `note` maps to Relation `notes`; the converted SourceReference is removed in the same operation. Relation-borne sourceRefs never convert (a Relation cannot be an edge endpoint) and are retained. `inspired-by` is retained, or a custom `namespace/name` relation type may be used — removal applies if an edge is created."
    },
    {
      "fieldId": "1a000032-0000-4000-a000-000000000032",
      "value": [
        "sourceRole",
        "Relation edge",
        "sourceInstanceId",
        "targetInstanceId"
      ]
    }
  ],
